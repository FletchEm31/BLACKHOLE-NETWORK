# Deployed as /etc/bhn-weather-collector.env (mode 600) on Helsinki and
# Hillsboro. Real credentials live in Proton Pass as
# "BHN-WeatherCollector-PG" — never commit actual values here.
#
# Uses the dedicated bhn_weather_collector PG role: INSERT+SELECT on the
# 6 bronze/legacy weather tables only (see docs/WeatherBHN for the full
# grant list). No Alpaca/trading credentials on these nodes by design —
# that's why this collector imports weather_core.py, not trading_core.py.

PG_HOST=10.8.0.1
PG_PORT=5432
PG_DB=eventhorizon
PG_USER=bhn_weather_collector
PG_PASSWORD=changeme

LOG_DIR=/var/log/bhn-weather
LOG_LEVEL=INFO
