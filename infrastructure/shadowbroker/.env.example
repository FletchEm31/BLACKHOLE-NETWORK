# Template for the ShadowBroker .env. Copy to `.env` in the
# ShadowBroker clone directory on the deploy host and fill in secrets.
# NEVER commit the real .env — this template is what lives in the repo.

# ── Bind ────────────────────────────────────────────────────────
# Set to the host IP the frontend should bind to. For BHN mesh-only:
# the WG interface address of the deploy host (e.g. 10.8.0.1 for LA).
BIND=

# ── Generated secrets (regenerate per deploy with openssl rand -hex 32) ──
# Protects admin endpoints. Set even for single-host dev — the upstream
# allows loopback without it, but anything mesh-internal still needs auth.
ADMIN_KEY=

# Mandatory per upstream compose. Shared transport auth for operator peer
# push. Generate per deploy; nothing to do with peers unless MESH_RELAY_PEERS
# is populated.
MESH_PEER_PUSH_SECRET=

# ── External API keys ───────────────────────────────────────────
# OpenSky Network — OAuth2 client (free at https://opensky-network.org/).
# Without these the flight layer falls back to ADS-B-only.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# aisstream.io — free tier WebSocket key for maritime AIS.
AIS_API_KEY=

# ── Optional ────────────────────────────────────────────────────
# Finnhub for market events (free tier)
FINNHUB_API_KEY=

# Singapore LTA traffic cameras (free)
LTA_ACCOUNT_KEY=

# CORS origins — comma-separated, e.g. http://10.8.0.4:8099
# Leave blank for auto-detect (loopback + LAN).
CORS_ORIGINS=

# Infonet mesh sync — upstream default is the public seed
MESH_DEFAULT_SYNC_PEERS=https://node.shadowbroker.info

# Operator-trusted peer push targets. Leave empty unless you've coordinated
# the peer secret on both sides.
MESH_RELAY_PEERS=
