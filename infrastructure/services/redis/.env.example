# BHN HORIZON Redis — LA hub only

# LA's WG tunnel IP (wg0). Do not change.
BIND_IP=10.8.0.1

# Paste value from Proton Pass entry "EH-Redis-Password".
# Never commit a real password to git. This file is .example; the live .env
# stays on LA in /opt/bhn-horizon-redis/.env and is in .gitignore.
REDIS_PASSWORD=REPLACE_ME
