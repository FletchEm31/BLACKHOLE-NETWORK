# BHN Tor relay — Frankfurt only

# Frankfurt's WG tunnel IP (used for SocksPort binding so local SearXNG
# can use Tor as upstream proxy)
BIND_IP=10.9.0.2

# Nickname, ContactInfo, bandwidth rate are HARDCODED in torrc (committed).
# To change them, edit torrc directly and restart the container.
#
# Current values in torrc:
#   Nickname     BHNFrankfurt
#   ContactInfo  admin@eventhorizonvpn.com
#   RelayBandwidthRate  1 MB
#   AccountingMax       1500 GB
