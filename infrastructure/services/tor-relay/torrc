# BHN — Tor non-exit middle relay configuration.
# Frankfurt node (BHN|VPS-FRANKFURT-EU1), 2026-05-11.
#
# Role: middle relay (also called guard once enough uptime accumulates).
# Forwards traffic between Tor nodes. NOT an exit. NOT a bridge.

## ─── Identity ──────────────────────────────────────────────────────────
Nickname BHNFornaxEU1
ContactInfo admin@eventhorizonvpn.com

## ─── Ports ─────────────────────────────────────────────────────────────
# ORPort: where other Tor nodes connect to us. Must be publicly reachable.
ORPort 9001

# SocksPort: local SOCKS5 proxy. Bound to 0.0.0.0 inside the container;
# the compose port-mapping restricts external exposure to the host's
# tunnel IP only (10.9.0.2:9050). Allows BHN services on Frankfurt to
# route their own egress through Tor.
SocksPort 0.0.0.0:9050

# DirPort: optional, helps directory authorities reach us. Middle relays
# don't strictly need it; leave commented to reduce attack surface.
# DirPort 9030

## ─── Relay type (explicit non-exit) ────────────────────────────────────
ExitRelay 0
ExitPolicy reject *:*       # belt + suspenders — refuse all exit traffic
BridgeRelay 0               # we're a middle relay, not a bridge

## ─── Bandwidth limits ──────────────────────────────────────────────────
# Vultr Frankfurt allowance: 2 TB/month. Cap to stay well under quota.
# 1 MB/s sustained ≈ 2.5 TB/month if fully used → cap rate + accounting.
RelayBandwidthRate 1 MB
RelayBandwidthBurst 2 MB

# Hard monthly cap. When hit, relay goes into hibernation until next cycle.
AccountingMax 1500 GB
AccountingStart month 1 00:00

## ─── Data + logging ────────────────────────────────────────────────────
DataDirectory /var/lib/tor
Log notice file /var/log/tor/notices.log
Log notice stdout         # also stream to docker logs

## ─── Hardening ─────────────────────────────────────────────────────────
# Force Tor to verify it's actually reachable on ORPort before publishing
# the descriptor. If UFW isn't open yet, the relay will log loudly instead
# of silently advertising an unreachable address.
AssumeReachable 0

# ControlSocket exposed for the BHN monitoring collector
# (scripts/bhn-tor-control-stats.py). CookieAuthentication keeps it password-
# free for processes that can read the cookie file; host-side mount + perms
# handled in docker-compose.yml. Socket path inside container is
# /var/lib/tor/control; bind-mounted out to /opt/bhn-tor-relay/control on host.
ControlSocket /var/lib/tor/control
ControlSocketsGroupWritable 1
CookieAuthentication 1
CookieAuthFileGroupReadable 1

## ─── MyFamily — LOAD-BEARING POST-DEPLOY STEP ─────────────────────────
# BHN runs (or plans) five relays — Fornax (Frankfurt EU1), Nebula (NJ US2),
# Helios (Hillsboro US3), Aurora (Sweden EU2, future), Eridanus (Iceland EU3,
# future). After EACH relay bootstraps and produces a fingerprint, MyFamily
# MUST be updated on ALL deployed torrc files so Tor consensus refuses to
# build circuits that pass through any two of them. Without MyFamily, the
# privacy benefit of running multiple relays is partially defeated.
# See infrastructure/docs/tor-relay-naming.md for the full roster.
#
# Get a fingerprint:
#   ssh <node> 'docker exec bhn-tor-relay cat /var/lib/tor/fingerprint'
#
# Then uncomment and edit ALL deployed torrc files identically:
# MyFamily $FORNAX_FP,$NEBULA_FP,$HELIOS_FP[,$AURORA_FP,$ERIDANUS_FP]
#
# Commit the updated torrc files to the repo with the actual fingerprints
# baked in — they're public information, not secrets. Restart every relay
# container after editing.
