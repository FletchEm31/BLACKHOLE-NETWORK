# BHN LibreSpeed — per-node environment.
# Copy to .env on each node and set BIND_IP to the node's WG tunnel address.
#
#   Frankfurt:  BIND_IP=10.9.0.2     # wg1 tunnel address
#   LA hub:     BIND_IP=10.8.0.1     # wg0 hub address
#   NJ:         BIND_IP=10.10.0.2    # wg2 (when tunnel is unblocked)
#
# Never use 0.0.0.0 here — LibreSpeed is VPN-only by design.

BIND_IP=
