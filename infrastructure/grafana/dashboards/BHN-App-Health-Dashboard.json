{
  "uid": "bhn-app-health",
  "title": "BHN \u2014 Application Health",
  "description": "Software layer: Docker containers, PostgreSQL stats, n8n workflow health, HORIZON activity. Data from container_stats, n8n_execution_stats, pg_stat_database, memories tables.",
  "tags": ["bhn", "app", "health", "application"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "\u2500\u2500 DOCKER CONTAINERS",
      "type": "row"
    },

    {
      "id": 1, "type": "table",
      "title": "Live Container Stats (latest snapshot)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT DISTINCT ON (container_name) container_name AS \"Container\", image AS \"Image\", cpu_pct AS \"CPU %\", mem_used_mb AS \"Mem Used (MB)\", mem_limit_mb AS \"Mem Limit (MB)\", mem_pct AS \"Mem %\", net_rx_bytes AS \"Net RX\", net_tx_bytes AS \"Net TX\", block_read_bytes AS \"Block R\", block_write_bytes AS \"Block W\", pids AS \"PIDs\", measured_at AS \"Last Sample\" FROM container_stats ORDER BY container_name, measured_at DESC" }],
      "options": { "showHeader": true, "footer": { "show": false }, "sortBy": [{ "displayName": "Container", "desc": false }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 90 }
              ]}}
            ]
          },
          { "matcher": { "id": "byName", "options": "Mem %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }
              ]}}
            ]
          },
          { "matcher": { "id": "byName", "options": "Mem Used (MB)" }, "properties": [{ "id": "unit", "value": "MB" }] },
          { "matcher": { "id": "byName", "options": "Mem Limit (MB)" }, "properties": [{ "id": "unit", "value": "MB" }] },
          { "matcher": { "id": "byName", "options": "Net RX" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Net TX" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Block R" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Block W" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Last Sample" }, "properties": [{ "id": "unit", "value": "dateTimeFromNow" }] }
        ]
      }
    },

    {
      "id": 2, "type": "timeseries",
      "title": "Container CPU % over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "time_series",
        "rawSql": "SELECT measured_at AS time, container_name AS metric, cpu_pct FROM container_stats WHERE $__timeFilter(measured_at) ORDER BY 1" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },

    {
      "id": 3, "type": "timeseries",
      "title": "Container Memory % over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "time_series",
        "rawSql": "SELECT measured_at AS time, container_name AS metric, mem_pct FROM container_stats WHERE $__timeFilter(measured_at) ORDER BY 1" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "\u2500\u2500 POSTGRESQL",
      "type": "row"
    },

    {
      "id": 10, "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT numbackends AS value FROM pg_stat_database WHERE datname = 'eventhorizon'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 30 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 11, "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT ROUND(blks_hit::numeric / NULLIF(blks_hit + blks_read, 0) * 100, 2) AS value FROM pg_stat_database WHERE datname = 'eventhorizon'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 95 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 12, "type": "stat",
      "title": "DB Size",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT pg_database_size('eventhorizon') AS value" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 13, "type": "stat",
      "title": "Total Transactions (lifetime)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 18 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT xact_commit + xact_rollback AS value FROM pg_stat_database WHERE datname = 'eventhorizon'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 14, "type": "table",
      "title": "Active Queries (non-idle)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT pid AS \"PID\", usename AS \"User\", application_name AS \"App\", state AS \"State\", ROUND(EXTRACT(EPOCH FROM (NOW() - query_start)), 1) AS \"Running (s)\", LEFT(query, 120) AS \"Query\" FROM pg_stat_activity WHERE datname = 'eventhorizon' AND state != 'idle' AND query NOT LIKE '%pg_stat_activity%' ORDER BY query_start ASC" }],
      "options": { "showHeader": true, "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Running (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }
              ]}}
            ]
          },
          { "matcher": { "id": "byName", "options": "State" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "mappings", "value": [{ "type": "value", "options": {
                "active":              { "color": "green",  "index": 0 },
                "idle in transaction": { "color": "yellow", "index": 1 },
                "idle in transaction (aborted)": { "color": "red", "index": 2 }
              }}]}
            ]
          }
        ]
      }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "\u2500\u2500 n8n WORKFLOW HEALTH",
      "type": "row"
    },

    {
      "id": 20, "type": "stat",
      "title": "Executions (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 31 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT COUNT(*) AS value FROM n8n_execution_stats WHERE started_at > NOW() - INTERVAL '24 hours'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 21, "type": "stat",
      "title": "Errors (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 31 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT COUNT(*) AS value FROM n8n_execution_stats WHERE status IN ('error','crashed') AND started_at > NOW() - INTERVAL '24 hours'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 22, "type": "stat",
      "title": "Avg Duration (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 31 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT ROUND(AVG(duration_ms)) AS value FROM n8n_execution_stats WHERE started_at > NOW() - INTERVAL '24 hours' AND duration_ms IS NOT NULL" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 23, "type": "stat",
      "title": "Success Rate (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 31 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE status = 'success')::numeric / NULLIF(COUNT(*), 0) * 100, 1) AS value FROM n8n_execution_stats WHERE started_at > NOW() - INTERVAL '24 hours'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 80 }, { "color": "green", "value": 95 }
          ]},
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 24, "type": "table",
      "title": "Workflow Status — Last Run per Workflow",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT DISTINCT ON (workflow_name) workflow_name AS \"Workflow\", status AS \"Status\", started_at AS \"Last Run\", ROUND(EXTRACT(EPOCH FROM (NOW() - started_at)) / 60, 0) AS \"Min Ago\", duration_ms AS \"Duration\", LEFT(COALESCE(error_message, ''), 100) AS \"Error\" FROM n8n_execution_stats ORDER BY workflow_name, started_at DESC" }],
      "options": { "showHeader": true, "footer": { "show": false }, "sortBy": [{ "displayName": "Workflow", "desc": false }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "mappings", "value": [{ "type": "value", "options": {
                "success":  { "color": "green",  "index": 0 },
                "error":    { "color": "red",    "index": 1 },
                "crashed":  { "color": "red",    "index": 2 },
                "running":  { "color": "blue",   "index": 3 },
                "canceled": { "color": "orange", "index": 4 },
                "waiting":  { "color": "yellow", "index": 5 }
              }}]}
            ]
          },
          { "matcher": { "id": "byName", "options": "Last Run" }, "properties": [{ "id": "unit", "value": "dateTimeAsIso" }] },
          { "matcher": { "id": "byName", "options": "Min Ago" }, "properties": [
            { "id": "unit", "value": "m" },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null }, { "color": "yellow", "value": 120 }, { "color": "red", "value": 1440 }
            ]}}
          ]},
          { "matcher": { "id": "byName", "options": "Duration" }, "properties": [{ "id": "unit", "value": "ms" }] }
        ]
      }
    },

    {
      "id": 25, "type": "timeseries",
      "title": "Executions by Status over time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 45 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [
        { "refId": "A", "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(started_at, '15m') AS time, 'success' AS metric, COUNT(*) FROM n8n_execution_stats WHERE status = 'success' AND $__timeFilter(started_at) GROUP BY 1 ORDER BY 1" },
        { "refId": "B", "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(started_at, '15m') AS time, 'error' AS metric, COUNT(*) FROM n8n_execution_stats WHERE status IN ('error','crashed') AND $__timeFilter(started_at) GROUP BY 1 ORDER BY 1" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "bars", "barAlignment": 0 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 103,
      "title": "\u2500\u2500 HORIZON ACTIVITY",
      "type": "row"
    },

    {
      "id": 30, "type": "stat",
      "title": "Total Memories",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 54 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT COUNT(*) AS value FROM memories" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },

    {
      "id": 31, "type": "stat",
      "title": "Last Memory Written",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 54 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT MAX(created_at) AS value FROM memories" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 32, "type": "stat",
      "title": "Conversations (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 54 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT COUNT(*) AS value FROM conversation_sessions WHERE created_at > NOW() - INTERVAL '24 hours'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 33, "type": "stat",
      "title": "Tokens Used (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 54 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT COALESCE(SUM(total_tokens), 0) AS value FROM agent_token_log WHERE logged_at > NOW() - INTERVAL '24 hours'" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },

    {
      "id": 34, "type": "table",
      "title": "Recent Memories",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 58 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT created_at AS \"Created\", memory_type AS \"Type\", importance AS \"Importance\", title AS \"Title\", source AS \"Source\" FROM memories ORDER BY created_at DESC LIMIT 20" }],
      "options": { "showHeader": true, "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "unit", "value": "dateTimeFromNow" }] },
          { "matcher": { "id": "byName", "options": "Importance" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "blue", "value": null }, { "color": "yellow", "value": 7 }, { "color": "red", "value": 9 }
              ]}}
            ]
          }
        ]
      }
    }

  ]
}
