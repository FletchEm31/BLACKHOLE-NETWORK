      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "title": "Buy Signals (24h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT COUNT(*) AS buy_signals FROM signals_log WHERE evaluated_at > NOW() - INTERVAL '24 hours' AND action = 'buy';", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 24 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "title": "Sell Signals (24h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT COUNT(*) AS sell_signals FROM signals_log WHERE evaluated_at > NOW() - INTERVAL '24 hours' AND action = 'sell';", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 14,
      "options": { "legend": { "calcs": ["last", "sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
