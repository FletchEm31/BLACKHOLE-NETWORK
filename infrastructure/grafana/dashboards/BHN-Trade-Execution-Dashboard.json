      "title": "Signals Acted On (24h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT COUNT(*) AS acted_on FROM signals_log WHERE evaluated_at > NOW() - INTERVAL '24 hours' AND acted_on = true;", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
