      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT ROUND(COALESCE(SUM(pnl), 0)::numeric, 2) AS total_pnl FROM paper_trades;", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }, "unit": "currencyUSD", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "title": "PnL Today",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT ROUND(COALESCE(SUM(pnl), 0)::numeric, 2) AS pnl_today FROM paper_trades WHERE filled_at >= CURRENT_DATE;", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "title": "Total Trades",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT COUNT(*) AS total_trades FROM paper_trades;", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 40 }, { "color": "green", "value": 55 }] }, "unit": "percent", "decimals": 1, "min": 0, "max": 100 } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 4,
      "options": { "minVizHeight": 50, "minVizWidth": 50, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Win Rate",
      "type": "gauge",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT ROUND((SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END)::numeric / NULLIF(COUNT(*), 0) * 100), 1) AS win_rate FROM paper_trades;", "format": "table", "refId": "A" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }, "unit": "currencyUSD", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "title": "Avg PnL per Trade",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT ROUND(AVG(pnl)::numeric, 2) AS avg_pnl FROM paper_trades;", "format": "table", "refId": "A" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "── PnL PERFORMANCE",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "currencyUSD" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cumulative PnL by Strategy",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT filled_at AS time, strategy_name, SUM(pnl) OVER (PARTITION BY strategy_name ORDER BY filled_at) AS cumulative_pnl FROM paper_trades ORDER BY filled_at ASC;", "format": "table", "refId": "A", "timeColumn": "time" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "currencyUSD" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Daily PnL (all strategies combined)",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT filled_at::date::timestamptz AS time, ROUND(SUM(pnl)::numeric, 2) AS daily_pnl FROM paper_trades GROUP BY filled_at::date ORDER BY filled_at::date ASC;", "format": "table", "refId": "A", "timeColumn": "time" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
