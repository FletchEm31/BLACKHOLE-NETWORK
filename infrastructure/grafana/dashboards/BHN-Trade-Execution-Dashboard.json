      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT date_trunc('hour', evaluated_at) AS time, action, COUNT(*) AS count FROM signals_log WHERE evaluated_at >= NOW() - INTERVAL '7 days' GROUP BY 1, 2 ORDER BY 1 ASC;", "format": "table", "refId": "A", "timeColumn": "time" }]
    },

    {
      "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "action" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "type": "value", "options": { "buy": { "color": "green", "index": 0 }, "sell": { "color": "red", "index": 1 }, "hold": { "color": "yellow", "index": 2 } } }] }] },
          { "matcher": { "id": "byName", "options": "acted_on" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "true": { "color": "green", "index": 0, "text": "✅" }, "false": { "color": "gray", "index": 1, "text": "—" } } }] }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
