      "targets": [{ "datasource": { "type": "postgres", "uid": "cflc7izgwm7lsc" }, "rawSql": "SELECT evaluated_at, strategy_id, ticker, action, acted_on::text, reason, value FROM signals_log ORDER BY evaluated_at DESC LIMIT 25;", "format": "table", "refId": "A" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
