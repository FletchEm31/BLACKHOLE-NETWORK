{
  "uid": "bhn-data-ingest",
  "title": "BHN Data Ingest Monitor",
  "description": "Live freshness + row counts for BHN's data pipelines: news, weather, pulse, security events, sessions. A panel going red = the upstream poll/workflow has stalled. Pre-req: grafana_reader role must have SELECT on news_articles + weather_snapshots (GRANT applied on LA before this dashboard works).",
  "tags": ["bhn", "ingest", "monitor"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "News articles (total rows)",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM news_articles"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Weather snapshots (total rows)",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM weather_snapshots"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pulse reports (total rows)",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM pulse_reports"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Security events — last 24h",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM security_events WHERE detected_at > NOW() - INTERVAL '24 hours'"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60000 },
              { "color": "red", "value": 120000 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active sessions (distinct users)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT user_key)::int AS value FROM sessions WHERE disconnected_at IS NULL"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "News — last fetch (min ago)",
      "description": "Green < 35 min (within one poll cycle). Yellow 35-90. Red > 90 = news poll is stalled. Cadence: every 30 min.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(fetched_at)))/60::numeric, 1) AS value FROM news_articles"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 35 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "short",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Weather — last fetch (min ago)",
      "description": "Green < 35 min. Yellow 35-90. Red > 90 = weather poll is stalled. Cadence: every 30 min.",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(fetched_at)))/60::numeric, 1) AS value FROM weather_snapshots"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 35 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "short",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Pulse — last generated (min ago)",
      "description": "Green < 130 min (within one 2h cycle + tolerance). Yellow 130-180. Red > 180 = pulse workflow has stalled. Cadence: every 2 hours.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "eventhorizon" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(generated_at)))/60::numeric, 1) AS value FROM pulse_reports"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 130 },
              { "color": "red", "value": 180 }
            ]
          },
          "unit": "short",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      }
    }
  ]
}
