      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT event_type, COUNT(*) AS count, MAX(severity) AS max_severity FROM security_events WHERE detected_at > NOW() - INTERVAL '24 hours' GROUP BY event_type ORDER BY count DESC LIMIT 15;",
        "format": "table", "refId": "A"
      }]
    },

