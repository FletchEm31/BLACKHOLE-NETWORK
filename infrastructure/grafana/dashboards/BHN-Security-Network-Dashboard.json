{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "BHN Security & Network — Nodes, Security Events, Anomalies, Pulse Reports, Node Logs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "── NODE STATUS",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "eventhorizon" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": {
              "online":          { "color": "green",  "index": 0, "text": "ONLINE" },
              "degraded":        { "color": "yellow", "index": 1, "text": "DEGRADED" },
              "offline":         { "color": "red",    "index": 2, "text": "OFFLINE" },
              "bootstrapping":   { "color": "blue",   "index": 3, "text": "BOOTSTRAPPING" },
              "decommissioned":  { "color": "gray",   "index": 4, "text": "DECOMMISSIONED" }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^status$/", "values": true },
        "textMode": "auto"
      },
      "title": "Node Status",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT name, status FROM nodes ORDER BY name ASC;",
        "format": "table", "refId": "A"
      }]
    },

    {
      "datasource": { "type": "postgres", "uid": "eventhorizon" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "status" }, "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "mappings", "value": [{ "type": "value", "options": {
              "online":        { "color": "green",  "index": 0 },
              "degraded":      { "color": "yellow", "index": 1 },
              "offline":       { "color": "red",    "index": 2 },
              "bootstrapping": { "color": "blue",   "index": 3 }
            }}]}
          ]},
          { "matcher": { "id": "byName", "options": "last_seen" }, "properties": [{ "id": "unit", "value": "dateTimeFromNow" }] }
        ]
      },
      "gridPos": { "h": 6, "w": 14, "x": 0, "y": 5 },
      "id": 2,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "Node Registry",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT name, type, region, public_ip::text, tunnel_ip::text, status, last_seen, bootstrap_version FROM nodes ORDER BY name ASC;",
        "format": "table", "refId": "A"
      }]
    },

    {
      "datasource": { "type": "postgres", "uid": "eventhorizon" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 3, "w": 5, "x": 14, "y": 5 },
      "id": 3,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^offline$/", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Nodes Offline",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT COUNT(*) AS offline FROM nodes WHERE status = 'offline';",
        "format": "table", "refId": "A"
      }]
    },

    {
      "datasource": { "type": "postgres", "uid": "eventhorizon" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 3, "w": 5, "x": 19, "y": 5 },
      "id": 4,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^online$/", "values": false },
        "textMode": "value_and_name"
      },
      "title": "Nodes Online",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT COUNT(*) AS online FROM nodes WHERE status = 'online';",
        "format": "table", "refId": "A"
      }]
    },

    {
      "datasource": { "type": "postgres", "uid": "eventhorizon" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "last_seen" }, "properties": [{ "id": "unit", "value": "dateTimeFromNow" }] }
        ]
      },
      "gridPos": { "h": 3, "w": 10, "x": 14, "y": 8 },
      "id": 5,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "Last Seen (per node)",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT name, last_seen, EXTRACT(EPOCH FROM (NOW() - last_seen))/60 AS minutes_ago FROM nodes ORDER BY last_seen DESC;",
        "format": "table", "refId": "A"
      }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 101,
