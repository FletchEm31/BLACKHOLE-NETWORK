      "title": "Top Attacking IPs (24h)",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "eventhorizon" },
        "rawSql": "SELECT source_ip, COUNT(*) AS attempts, MAX(severity) AS max_severity, MAX(detected_at) AS last_seen FROM security_events WHERE detected_at > NOW() - INTERVAL '24 hours' AND source_ip IS NOT NULL GROUP BY source_ip ORDER BY attempts DESC LIMIT 15;",
        "format": "table", "refId": "A"
      }]
    },

    {
      "datasource": { "type": "postgres", "uid": "eventhorizon" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } }
