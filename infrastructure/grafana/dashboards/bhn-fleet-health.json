{
  "uid": "eh-fleet-health",
  "title": "EH Fleet Health",
  "description": "Per-node liveness derived from the nodes registry + 5-min heartbeat cron. A node is stale when its last_seen is older than three missed heartbeats (15 min).",
  "tags": ["eh", "fleet", "heartbeat"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Online vs stale",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT  SUM(CASE WHEN last_seen >= NOW() - INTERVAL '15 minutes' THEN 1 ELSE 0 END) AS online,  SUM(CASE WHEN last_seen <  NOW() - INTERVAL '15 minutes' OR last_seen IS NULL THEN 1 ELSE 0 END) AS stale FROM nodes WHERE status NOT IN ('decommissioned')"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "online" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]}}
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Stale nodes (no heartbeat > 15 min)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT name, type, region, status, last_seen, EXTRACT(EPOCH FROM (NOW() - last_seen))/60 AS minutes_stale, public_ip, tunnel_ip FROM nodes WHERE (last_seen < NOW() - INTERVAL '15 minutes' OR last_seen IS NULL) AND status NOT IN ('decommissioned') ORDER BY last_seen NULLS FIRST"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "minutes_stale" },
            "properties": [
              { "id": "unit", "value": "m" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "yellow", "value": null },
                { "color": "orange", "value": 60 },
                { "color": "red", "value": 240 }
              ]}}
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "All nodes (registry)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT id, name, type, region, status, last_seen, EXTRACT(EPOCH FROM (NOW() - last_seen))/60 AS minutes_since_heartbeat, bootstrap_version, public_ip, tunnel_ip FROM nodes ORDER BY type, region, name"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "minutes_since_heartbeat" },
            "properties": [
              { "id": "unit", "value": "m" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "mappings", "value": [
                { "type": "value", "options": { "online":         { "color": "green",  "index": 0 }}},
                { "type": "value", "options": { "bootstrapping":  { "color": "blue",   "index": 1 }}},
                { "type": "value", "options": { "degraded":       { "color": "orange", "index": 2 }}},
                { "type": "value", "options": { "offline":        { "color": "red",    "index": 3 }}},
                { "type": "value", "options": { "decommissioned": { "color": "gray",   "index": 4 }}}
              ]},
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      }
    }
  ]
}
