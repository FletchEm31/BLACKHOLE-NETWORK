{
  "uid": "bhn-node-resources",
  "title": "BHN Node Resources",
  "description": "Per-node CPU/RAM/load/disk from bhn-resource-collector.sh (5-min cadence).",
  "tags": ["bhn", "resources", "host"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "CPU% per node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "time_series",
        "rawSql": "SELECT measured_at AS time, node_name AS metric, cpu_pct FROM node_resource_stats WHERE $__timeFilter(measured_at) ORDER BY 1" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 2, "type": "timeseries", "title": "Memory used % per node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "time_series",
        "rawSql": "SELECT measured_at AS time, node_name AS metric, (mem_used_mb::float / NULLIF(mem_total_mb,0)) * 100 AS mem_pct FROM node_resource_stats WHERE $__timeFilter(measured_at) ORDER BY 1" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 3, "type": "timeseries", "title": "Load average (1m) per node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "time_series",
        "rawSql": "SELECT measured_at AS time, node_name AS metric, load_1m FROM node_resource_stats WHERE $__timeFilter(measured_at) ORDER BY 1" }]
    },
    {
      "id": 4, "type": "table", "title": "Disk usage (latest, per node × mount)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cflc7izgwm7lsc" },
      "targets": [{ "refId": "A", "format": "table",
        "rawSql": "SELECT DISTINCT ON (node_name, mount_point) node_name, mount_point, filesystem, used_pct, used_kb/1024/1024 AS used_gb, total_kb/1024/1024 AS total_gb FROM node_disk_stats ORDER BY node_name, mount_point, measured_at DESC" }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "used_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ]}}
            ]
          }
        ]
      }
    }
  ]
}
