            "uid": "eventhorizon"
          },
          "format": "table",
          "rawSql": "SELECT name, type, region, status, last_seen, EXTRACT(EPOCH FROM (NOW() - last_seen))/60 AS minutes_stale, public_ip, tunnel_ip FROM nodes WHERE (last_seen < NOW() - INTERVAL '15 minutes' OR last_seen IS NULL) AND status NOT IN ('decommissioned') ORDER BY last_seen NULLS FIRST",
