      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "eventhorizon"
          },
          "format": "table",
          "rawSql": "SELECT  SUM(CASE WHEN last_seen >= NOW() - INTERVAL '15 minutes' THEN 1 ELSE 0 END) AS online,  SUM(CASE WHEN last_seen <  NOW() - INTERVAL '15 minutes' OR last_seen IS NULL THEN 1 ELSE 0 END) AS stale FROM nodes WHERE status NOT IN ('decommissioned')",
          "refId": "A"
        }
      ],
      "title": "Online vs stale",
      "type": "stat"
    },
