# Secrets / env (never commit credentials)
*.env
!*.env.example
.eh-*.env
.env.*
!.env.example
*.key
*.pem
!letsencrypt-fullchain.example.pem
*_secret*
*_credentials*

# Backup files (created by sed -i.bak, editors)
*.bak
*.bak.*
*~
*.orig
*.swp
*.swo

# Logs
*.log
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# Node
node_modules/
.pnp.*
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build / dist
dist/
build/
*.egg-info/

# Editor / IDE
.vscode/
.idea/
*.iml

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Claude Code local state (per-machine, not for sharing)
.claude/

# Session handoff docs — internal operational notes (IPs, CVE status, BTEH findings)
# Not for public consumption; maintained locally by operator only
infrastructure/docs/BHN SESSION UPDATES/
infrastructure/docs/BHN session updates/

# Local-only ops artifacts
*.local.*
*.private.*

# Backup archives (off-host drops live in D:\EH Backups\, never the repo)
n8n-backup.tar.gz
*.tar.gz

# Scraper operational data — CSVs, Excel exports, master output XLSX are all
# sensitive scrape outputs; keep the folder structure (.gitkeep), not contents
infrastructure/scrapers/data/*
!infrastructure/scrapers/data/.gitkeep

# Scraper runtime state — checkpoints/, dead-proxy lists, captured pages
infrastructure/scrapers/checkpoints/

# Local export tool credentials (Windows operator runs export-master.js)
infrastructure/scrapers/.export-master.env
